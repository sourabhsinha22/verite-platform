NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Email notifications via Resend (https://resend.com)
# Install: npm install resend
RESEND_API_KEY=re_your_api_key_here

# App URL for generating links in emails and payment pages
NEXT_PUBLIC_APP_URL=https://verite-platform.vercel.app

# Supabase service role key (server-side only — never expose to browser)
# Found at: supabase.com/dashboard/project/_/settings/api
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Cron job secret — any random string, must match what Vercel sends
CRON_SECRET=your_cron_secret_here

# Apollo.io API key — for outreach and lead generation
# Found at: app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=your_apollo_api_key_here
